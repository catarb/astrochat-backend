                  "pm.test(\"Código esperado\", function () { pm.expect([200, 400, 401, 403]).to.include(pm.response.code); });",
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  const data = json.data || {};",
                  "  if (data.token) {",
                  "    pm.collectionVariables.set(\"token\", data.token);",
                  "    if (pm.environment && pm.environment.name) pm.environment.set(\"token\", data.token);",
                  "  }",
                  "  const id = data.user && (data.user._id || data.user.id);",
                  "  if (id) {",
                  "    pm.collectionVariables.set(\"userId\", id);",
